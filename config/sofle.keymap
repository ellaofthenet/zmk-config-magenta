#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        // Layer 0 - placeholder base layer (60 positions).
        default_layer {
            display-name = "Base";
            bindings = <
&kp ESC   &kp N1 &kp N2   &kp N3   &kp N4    &kp N5                          &kp N6   &kp N7    &kp N8    &kp N9   &kp N0   &kp GRAVE
&kp TAB   &kp Q  &kp W    &kp E    &kp R     &kp T                           &kp Y    &kp U     &kp I     &kp O    &kp P    &kp BSPC
&kp LSHFT &kp A  &kp S    &kp D    &kp F     &kp G                           &kp H    &kp J     &kp K     &kp L    &kp SEMI &kp SQT
&kp LCTRL &kp Z  &kp X    &kp C    &kp V     &kp B   &kp C_MUTE   &kp C_MUTE  &kp N    &kp M     &kp COMMA &kp DOT  &kp FSLH &kp RSHFT
                 &kp LGUI &kp LALT &kp LCTRL &mo 1   &kp SPACE    &kp RET     &mo 2    &kp RCTRL &kp RALT  &kp RGUI
            >;
            sensor-bindings = <&inc_dec_kp C_VOLUME_UP C_VOLUME_DOWN>;
        };

        // Layer 1 - hold the left-thumb key (&mo 1) to reach these.
        // Everything here is on the LEFT half, so it works over USB with
        // only the left side plugged in.
        //   BT_CLR  : clear the pairing on the CURRENT profile
        //   BT_SEL n: switch to Bluetooth profile n (0-4)
        //   OUT_USB / OUT_BLE / OUT_TOG: force where keystrokes are sent
        //   bootloader / sys_reset: flash / reboot helpers
        lower_layer {
            display-name = "Lower";
            bindings = <
&bt BT_CLR   &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &bt BT_SEL 4                 &trans &trans &trans &trans &trans &trans
&out OUT_USB &out OUT_BLE &out OUT_TOG &trans       &trans       &trans                       &trans &trans &trans &trans &trans &trans
&bootloader  &sys_reset   &trans       &trans       &trans       &trans                       &trans &trans &trans &trans &trans &trans
&trans       &trans       &trans       &trans       &trans       &trans  &trans     &trans     &trans &trans &trans &trans &trans &trans
                          &trans       &trans       &trans       &trans  &trans     &trans     &trans &trans &trans &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOLUME_UP C_VOLUME_DOWN>;
        };

        // Layer 2 - placeholder so &mo 2 has somewhere to go.
        raise_layer {
            display-name = "Raise";
            bindings = <
&trans &trans &trans &trans &trans &trans                 &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans                 &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans                 &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans &trans   &trans &trans &trans &trans &trans &trans &trans
              &trans &trans &trans &trans &trans   &trans &trans &trans &trans &trans
            >;
            sensor-bindings = <&inc_dec_kp C_VOLUME_UP C_VOLUME_DOWN>;
        };
    };
};
